{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "mini-mos",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-01",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DATABASE",
			"database_name": "database",
			"database_id": "database"
		}
	]
}
